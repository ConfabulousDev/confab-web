# =============================================================================
# Confabulous — self-host configuration
# =============================================================================
# Copy this file to `.env` next to docker-compose.yml and edit for production:
#
#     cp .env.example .env
#
# Everything here is OPTIONAL: with no .env (or all lines commented) the stack
# runs with safe localhost eval defaults — `docker compose up -d` gives you a
# working dashboard at http://localhost:8080 (admin@local.dev / localdevpassword).
#
# For a real deployment, work through the sections below. See the full reference
# at https://docs.confabulous.dev/self-hosting/configuration/ and the walkthrough
# at https://docs.confabulous.dev/self-hosting/deploy/.
# =============================================================================


# ── Secrets (set these for production) ───────────────────────────────────────
# Generate each with:  openssl rand -base64 32   (CSRF)  /  openssl rand -base64 24
# CSRF secret — MUST be at least 32 characters.
# CSRF_SECRET_KEY=replace-me-with-openssl-rand-base64-32
# Replace the bundled Postgres / MinIO default credentials.
# POSTGRES_PASSWORD=replace-me
# MINIO_ROOT_USER=replace-me
# MINIO_ROOT_PASSWORD=replace-me

# ── Public URLs & cookies (production) ───────────────────────────────────────
# Set all three to your public URL (usually identical). Then turn off dev mode.
# FRONTEND_URL=https://confab.example.com
# BACKEND_URL=https://confab.example.com
# ALLOWED_ORIGINS=https://confab.example.com
# INSECURE_DEV_MODE=false

# ── HTTPS (Caddy profile) ────────────────────────────────────────────────────
# Used by `docker compose --profile caddy up -d`. Point an A record at this host.
# CONFAB_DOMAIN=confab.example.com

# ── Admin bootstrap ──────────────────────────────────────────────────────────
# Creates the first admin on startup when no users exist. Choose a strong
# password, then REMOVE these after first login.
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=a-strong-password
# Comma-separated emails with access to the admin panel (/admin/users).
# SUPER_ADMIN_EMAILS=admin@example.com

# ── Authentication ───────────────────────────────────────────────────────────
# At least one method must be enabled. Password auth is on by default.
# AUTH_PASSWORD_ENABLED=true
# Restrict logins to specific email domains (applies to all methods).
# ALLOWED_EMAIL_DOMAINS=company.com,partner.com
# Auto-link a first-time OAuth login to an existing same-email account. Default
# false rejects it (prevents takeover via an attacker-controlled IdP email).
# OAUTH_AUTO_LINK_EMAIL=false
#
# GitHub OAuth — create an app at https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URL=https://confab.example.com/auth/github/callback
#
# Google OAuth — https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URL=https://confab.example.com/auth/google/callback
#
# Generic OIDC (Okta, Auth0, Azure AD, Keycloak, …). All four required.
# OIDC_ISSUER_URL=https://your-idp.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=https://confab.example.com/auth/oidc/callback
# OIDC_DISPLAY_NAME=SSO

# ── Team & sharing ───────────────────────────────────────────────────────────
# Make every session visible to all authenticated users (small trusted teams).
# SHARE_ALL_SESSIONS_TO_AUTHENTICATED=false
# Allow users to create external share links.
# ENABLE_SHARE_CREATION=true
# Org-wide per-user analytics visible to every authenticated user (trusted teams).
# ENABLE_ORG_ANALYTICS=false
# Max registered users (default 50). Set to 0 to block new registrations.
# MAX_USERS=50

# ── Smart recaps (optional, Anthropic API) ───────────────────────────────────
# AI session summaries. Get a key at https://console.anthropic.com/
# SMART_RECAP_ENABLED=true
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# SMART_RECAP_MODEL=claude-haiku-4-5-20251001
# SMART_RECAP_QUOTA_LIMIT=500          # per-user monthly cap; 0/unset = unlimited

# ── Email (optional, for share invitations) ──────────────────────────────────
# Sign up at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME=Confab
# SUPPORT_EMAIL=support@example.com

# ── External Postgres / S3 (optional) ────────────────────────────────────────
# To use a managed database or S3 provider instead of the bundled containers,
# set these and remove the corresponding service(s) from docker-compose.yml.
# DATABASE_URL=postgres://user:pass@db-host:5432/confab?sslmode=require
# S3_ENDPOINT=s3.amazonaws.com          # no http(s):// prefix
# S3_USE_SSL=true
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# BUCKET_NAME=your-bucket

# ── Security / advanced ──────────────────────────────────────────────────────
# Behind a known edge proxy, restrict which proxy headers are trusted for
# client-IP extraction so they can't be spoofed (e.g. Fly-Client-IP).
# TRUSTED_PROXY_HEADERS=
# Worker cadence (the bundled compose uses a faster poll for responsiveness).
# WORKER_POLL_INTERVAL=1m
# WORKER_MAX_SESSIONS=10
# Air-gapped only: disable the runtime model-price fetch (uses embedded table).
# Leave the value empty to disable fetching entirely.
# PRICING_SOURCE_URL=
