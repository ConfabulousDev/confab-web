<style>
  .provider-strip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    /* Pull up tight under the hero actions — the splash content panel already
       adds its own top spacing, so keep this small (slightly negative) to avoid
       a large gap below the Get Started button. */
    margin: -1rem 0 0.5rem;
  }

  .provider-strip__eyebrow {
    font-size: var(--sl-text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  .provider-strip__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem 2.5rem;
  }

  .provider-strip__item {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: var(--sl-text-lg);
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .provider-strip__mark {
    width: 1.75rem;
    height: 1.75rem;
    flex-shrink: 0;
  }

  /* OpenCode is monochrome — inherit the docs text color via currentColor. */
  .provider-strip__mark--mono {
    color: var(--sl-color-white);
  }
</style>
